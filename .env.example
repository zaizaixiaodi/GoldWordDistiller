# TikHub API
TIKHUB_API_KEY=<your-tikhub-api-key>

# 飞书多维表 ID
# 注意：如果多维表嵌在 Wiki 中（URL 含 /wiki/），这里填的是 wiki node 的 obj_token，
# 不是 URL 里的 wiki node token。通过 lark-cli wiki node get --token <wiki_token> 查询。
FEISHU_BITABLE_APP_TOKEN=<bitable-obj-token>
FEISHU_HOTPOSTS_TABLE_ID=<hotposts-table-id>
FEISHU_GOLDWORDS_TABLE_ID=<goldwords-table-id>
FEISHU_CONFIG_TABLE_ID=<config-table-id>
FEISHU_PATTERNS_TABLE_ID=<patterns-table-id>

# 飞书自建应用（备用，供 Python 直接调 API 时使用；lark-cli 用自己的应用）
FEISHU_APP_ID=<feishu-app-id>
FEISHU_APP_SECRET=<feishu-app-secret>
